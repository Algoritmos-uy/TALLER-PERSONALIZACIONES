# MusaCreativa — Variables de entorno
# Copiá este archivo como .env y completá los valores reales

# ── Servidor ──────────────────────────────────────────────
PORT=3000

# ── IA (Anthropic Claude) ─────────────────────────────────
# Obtené tu API key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ── Base de datos ─────────────────────────────────────────
# Por defecto usa SQLite local. Dejá en blanco para usar el default.
DB_PATH=./backend/database/db.sqlite

# ── Contacto (usados en templates de email) ───────────────
CONTACT_EMAIL=hola@musacreativa.com.ar
WHATSAPP_NUMBER=5491100000000
